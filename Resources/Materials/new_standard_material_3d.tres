render_priority = 0
shader = SubResource("Shader_kb5ly")
shader_parameter/clipping_height = 1.0
shader_parameter/cap_color = Color(0, 0, 0, 1)
shader_parameter/cap_normal = Color(0, 1, 0, 1)
shader_parameter/albedo = Color(1, 1, 1, 1)
shader_parameter/texture_albedo = ExtResource("1_32l5l")
shader_parameter/albedo_texture_size = Vector2i(1024, 1024)
shader_parameter/point_size = 1.0
shader_parameter/roughness = 0.6
shader_parameter/metallic_texture_channel = Vector4(1, 0, 0, 0)
shader_parameter/specular = 0.5
